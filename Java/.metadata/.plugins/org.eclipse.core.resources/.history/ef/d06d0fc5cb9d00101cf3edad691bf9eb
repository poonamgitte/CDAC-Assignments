
public class Date {
	
	public int day;
	public int month;
	public int year;
	
	
	public void acceptDate() {
		int d,m,y;
		
		System.out.println("Enter day:");
		d = ConsoleInput.getInteger();
		m = ConsoleInput.getInteger();
		y = ConsoleInput.getInteger();
		
		setDate(d,m,y);
	}
	
	public void setDate(int day, int month, int year) {
		
		boolean leap;
		
		if(year%4 == 0 && year%100 != 0) 
			leap =true;
		else if(year%400 == 0) {
			leap = true;
		}
		else {
			leap = false;
		}
		
		
		
		if(day <1 || day > 31) {
			this.day = 1;
		}
		else {
			if(leap && month == 2 && day <=29) {				
				this.day = day;
			}
			else if(!leap && month == 2 && day <=28) {
				this.day = day;
			}
			else {
				this.day = 1;
			}
		}
		
		if(month < 1 || month > 12) {
			this.month = 1;
		}
		else {
			this.month = month;
		}
		
		if(year < 1900 || year > 2030) {
			this.year = 2025;
		}
		else {
			this.year = year;
		}
	}
	
	public int getDay() {
		return this.day;
	}
	
	public int getMonth() {
		return this.month;
	}
	
	public int getYear() {
		return this.year;
	}

}
