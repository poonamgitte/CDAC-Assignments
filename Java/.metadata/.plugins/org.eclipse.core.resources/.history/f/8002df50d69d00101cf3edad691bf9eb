
public class Date {
	
	public int day;
	public int month;
	public int year;
	
	
	public void acceptDate() {
		int d,m,y;
		
		System.out.println("Enter day:");
		d = ConsoleInput.getInteger();
		
		System.out.println("Enter month:");
		m = ConsoleInput.getInteger();
		
		System.out.println("Enter year:");
		y = ConsoleInput.getInteger();
		
		setDate(d,m,y);
	}
	
	public void setDate(int day, int month, int year) {
		
		boolean leap;
		
		if(year%4 == 0 && year%100 != 0) 
			leap =true;
		else if(year%400 == 0) {
			leap = true;
		}
		else {
			leap = false;
		}
		
		
		
		if(day <1) {
			this.day = 1;
		}else if((month==1||month==3||month==5||month==7||month==8||month==10||month==12) && (day<=31)) {
			this.day=day;
		}else if((month==4||month==6||month==9||month==11) && (day<=30)) {
			this.day=day;
		}
		else if(leap && month == 2 && day <=29) {				
				this.day = day;
		}
		else if(!leap && month == 2 && day <=28) {
				this.day = day;
		}
		
		else {
				this.day = 1;
			}
		
		
		if(month < 1 || month > 12) {
			this.month = 1;
		}
		else {
			this.month = month;
		}
		
		if(year < 1900 || year > 2030) {
			this.year = 2025;
		}
		else {
			this.year = year;
		}
	}
	
	public int getDay() {
		return this.day;
	}
	
	public int getMonth() {
		return this.month;
	}
	
	public int getYear() {
		return this.year;
	}
		
	public void displayDate() {
		System.out.println(day+"/"+month+"/"+year);
	}
	
	// Function to add months
	public void addMonths(int months) {
		
		int d= getDay();
		int m = getMonth();
		int y = getYear();
		
		int totalMonths = m+months;
		
		if(totalMonths > 12) {
			m = totalMonths%12;
			y = y + totalMonths/12;
		}
		else {
			m = m+months;
		}
		
		setDate(d,m,y);
	}
	
	// Function to add year
	public void addYear(int year) {
		int d= getDay();
		int m = getMonth();
		int y = getYear();
		
		setDate(d, m, y+year);
		
	}
	
