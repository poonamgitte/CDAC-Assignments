
public class SumOfPrime {
	
	static boolean isPrime(int n) {
		
		if(n<=1)
			return false;
		for(int i=2;i<=n/2;i++) {
			if(n%i==0)
				return false;	
		}
		return true;
	}
	
	static int primeSum() {
		int sum=0;
		int count =0;
		for(int i=0;;i++) {
			if (count > 100) {
				break;
			}
			
			if(isPrime(i)) {
				sum += i;
				count++;
			}
		}
		return sum;
		
	}
	public static void main(String[] args) {
		System.out.println("Sum of prime between 1 to 100:"+primeSum());
	}
}
