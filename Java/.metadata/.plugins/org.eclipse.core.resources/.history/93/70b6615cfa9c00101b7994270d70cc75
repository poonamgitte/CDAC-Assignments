
public class SumOfPrime {
	
	static boolean isPrime(int n) {
		
		for(int i=0;i<n/2;i++) {
			if(n%i==0)
				return false;	
		}
		return true;
	}
	
	static int primeSum() {
		int sum=0;
		for(int i=0;i<100;i++) {
			if(isPrime(i))
				sum += i;
		}
		return sum;
		
	}
	public static void main(String[] args) {
		System.out.println("Sum of prime between 1 to 100:"+primeSum());
	}
}
